# clawd-calendar configuration
# ─────────────────────────────
# Copy to .clawd-calendar.env (gitignored) and edit. Every value is optional —
# defaults shown. Real env vars override this file.

# ── who / where ──────────────────────────────────────────────────────────
CAL_OWNER_NAME=the host                  # shown on the booking page
CAL_OWNER_TZ=America/Denver              # IANA timezone your rules are defined in
CAL_CALENDAR_ID=primary                  # Google calendar bookings land on
CAL_BASE_URL=http://127.0.0.1:8788       # public URL, used in minted links
CAL_PORT=8788

# ── standard availability window (in CAL_OWNER_TZ) ───────────────────────
CAL_WINDOW_DAYS=mon,tue,wed,thu,fri
CAL_WINDOW_START=08:00
CAL_WINDOW_END=17:00

# ── vip/override window (wider — "any time I'm free") ────────────────────
CAL_VIP_DAYS=mon,tue,wed,thu,fri,sat,sun
CAL_VIP_START=08:00
CAL_VIP_END=21:00

# ── slot shape ────────────────────────────────────────────────────────────
CAL_SLOT_MINUTES=60                      # call length
CAL_SLOT_STEP_MINUTES=30                 # start-time increments
CAL_BUFFER_BEFORE_MINUTES=15             # prep time needed before a call
CAL_BUFFER_AFTER_MINUTES=0
CAL_MIN_NOTICE_HOURS=2                   # earliest a guest can book from "now"
CAL_NO_SAME_DAY=false                    # true → today is never offered
CAL_MAX_DAYS_OUT=21                      # how far ahead guests can book

# ── daily cap ─────────────────────────────────────────────────────────────
CAL_DAILY_CAP=1                          # max tool-booked calls per day (0 = off)
CAL_CAP_COUNTS=tool                      # tool = only calls booked here close a day
                                         # any  = any busy calendar event closes it

# ── event ─────────────────────────────────────────────────────────────────
CAL_EVENT_TITLE=Call: {name}             # {name} → guest's name
CAL_ADD_MEET=true                        # attach a Google Meet link

# ── access ────────────────────────────────────────────────────────────────
#CAL_PUBLIC_TOKEN=                       # "shields down": visiting / without a
                                         # password acts as this token. Unset =
                                         # landing page asks for a password.

# ── booking page info panel (all optional) ────────────────────────────────
#CAL_PAGE_TITLE=Chat with Austin         # default: "Book a call with <CAL_OWNER_NAME>"
#CAL_PAGE_DESCRIPTION=A quick call about whatever you're building.
#CAL_AVATAR_URL=https://example.com/me.jpg

# ── google oauth (filled in by `node scripts/auth.js`) ────────────────────
#GCAL_CLIENT_ID=
#GCAL_CLIENT_SECRET=
#GCAL_REFRESH_TOKEN=
